# Runpod Flash endpoints
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID_EMBEDDER=your_embedder_endpoint_id   # BGE-M3 endpoint
RUNPOD_ENDPOINT_ID_LLM=your_llm_endpoint_id             # Qwen3.5-2B endpoint

# Bright Data
BRIGHT_DATA_API_KEY=your_bright_data_api_key
BRIGHT_DATA_ZONE=your_zone_name  # e.g. residential

# Freightos (optional — free public API, no key needed for basic use)
FREIGHTOS_API_KEY=

# Supabase (same project as TariffLens — new tables only)
SUPABASE_URL=https://qszregcopfbiavgwvfip.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here  # Settings → API → service_role key

# Demo mode: returns pre-cached data without hitting APIs (set to "true" for quick demo)
DEMO_MODE=false
